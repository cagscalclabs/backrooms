	ld	a, (ix - 22)
	add	a, 2
	push	bc
	pop	hl
	ld	de, 8
	or	a, a
	sbc	hl, de
	jp	nz, BB1_2
	ld	bc, (ix - 47)
	inc	bc
	ld	iy, (ix - 40)
	lea	iy, iy + 64
