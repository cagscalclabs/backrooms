	ld	a, b
	and	a, 15
	cp	a, 6
	ld	c, (ix - 19)
	jr	c, BB1_36
	cp	a, 11
	ld	c, (ix - 20)
	jr	c, BB1_36
BB1_35:
	ld	c, h
BB1_36:
	ld	iy, (ix - 3)
	add	iy, de
	ld	(iy), c
	inc	de
	inc	b
	push	de
	pop	hl
	ld	a, b
	ld	bc, 8
	or	a, a
	sbc	hl, bc
	ld	b, a
	jp	nz, BB1_3
	ld	bc, (ix - 25)
	inc	bc
	ld	iy, (ix - 18)
	lea	iy, iy + 8
